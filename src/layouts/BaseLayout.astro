---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = 'Erik Zettersten — AI Developer, Engineer, Strategist, Leader.',
  image = '/og-default.svg',
  type = 'website',
  publishedTime,
  modifiedTime,
  noindex = false,
  jsonLd,
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://zettersten.com';
const canonical = new URL(Astro.url.pathname, site).toString();
const imageUrl = image.startsWith('http') ? image : new URL(image, site).toString();
const robots = noindex ? 'noindex, nofollow' : 'index, follow';

const publishedISO = publishedTime ? new Date(publishedTime).toISOString() : undefined;
const modifiedISO = modifiedTime ? new Date(modifiedTime).toISOString() : undefined;

const baseSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'zettersten.com',
  url: site,
};
const extraSchema = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const schemaGraph = [baseSchema, ...extraSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={robots} />

    <meta name="author" content="Erik Zettersten" />
    <meta name="application-name" content="zettersten.com" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#ebebeb" />

    <meta property="og:site_name" content="zettersten.com" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    {publishedISO && <meta property="article:published_time" content={publishedISO} />}
    {modifiedISO && <meta property="article:modified_time" content={modifiedISO} />}
    {type === 'article' && <meta property="article:author" content="Erik Zettersten" />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="mask-icon" href="/favicon.svg" color="#c7632c" />

    <link
      rel="alternate"
      type="application/rss+xml"
      title="Erik Zettersten Blog RSS"
      href="/rss.xml"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #ebebeb;
    --panel: #f7f7f7;
    --text: #161616;
    --muted: #696969;
    --line: #d7d7d7;
    --border: #d0d0d0;
    --radius: 26px;
    --brand: #c7632c;
    --font-sans: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --font-serif: 'Source Serif 4', Georgia, 'Times New Roman', serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    --container-max: 1120px;
    --space-page-top: 1.8rem;
    --space-page-bottom: 2.4rem;
    --measure: 68ch;
  }

  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
  }
  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    font-size: 16px;
    line-height: 1.65;
    letter-spacing: 0;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-serif);
    letter-spacing: -0.015em;
    line-height: 1.06;
    margin: 0 0 0.6rem;
  }

  p,
  li {
    max-width: 70ch;
  }

  a {
    color: inherit;
    text-decoration: none;
  }
  .container {
    width: min(var(--container-max), calc(100% - 2.2rem));
    margin-inline: auto;
  }
  .page-shell {
    padding-top: var(--space-page-top);
    padding-bottom: var(--space-page-bottom);
  }
  .page-hero {
    max-width: 860px;
    margin-bottom: 1rem;
  }
  .page-title {
    margin: 0.35rem 0 0.6rem;
    font-size: clamp(2.2rem, 6vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
  }
  .page-subtitle {
    margin: 0;
    max-width: var(--measure);
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.7;
  }
  .kicker {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    font-weight: 600;
  }
  .glass {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    border: 1px solid #c8c8c8;
    font-weight: 500;
    font-size: 0.82rem;
    color: #222;
    background: #f3f3f3;
    transition: background 0.16s ease;
  }
  .btn:hover {
    background: #e8e8e8;
  }
  .btn.primary {
    background: #202020;
    color: #fff;
    border-color: #202020;
  }
  .muted {
    color: var(--muted);
  }

  :focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 2px;
    border-radius: 6px;
  }

  .skip-link {
    position: absolute;
    left: 0.6rem;
    top: -100px;
    background: #101010;
    color: #fff;
    padding: 0.5rem 0.7rem;
    border-radius: 8px;
    z-index: 999;
    font-size: 0.85rem;
  }
  .skip-link:focus {
    top: 0.6rem;
  }

  ::selection {
    background: #f0d2c2;
    color: #171717;
  }
</style>
