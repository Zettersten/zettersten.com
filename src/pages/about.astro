---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights, linkedinHighlights } from '../data/projects';
---

<BaseLayout
  title="About Erik Zettersten"
  description="Background, operating style, and leadership approach from Erik Zettersten."
  image="/images/erik-home.jpg"
>
  <Nav />
  <main id="main-content" class="container page page-shell">
    <header class="intro page-hero">
      <p class="kicker">About</p>
      <h1 class="page-title">I’m an operator who likes unfinished systems and hard problems.</h1>
      <p class="lead page-subtitle">
        I’ve spent my career building in moments where the map doesn’t exist yet: fintech,
        blockchain, AI platforms, and mission-critical data systems. The work is messy, but that’s
        where leverage lives.
      </p>
    </header>

    <section class="top-grid">
      <article class="glass card">
        <h2>What I optimize for</h2>
        <ul>
          <li>Clear decision-making over endless alignment theater.</li>
          <li>Reliable systems over flashy demos.</li>
          <li>Shipped outcomes over roadmap storytelling.</li>
          <li>Teams that can execute under pressure without burning out.</li>
        </ul>
      </article>

      <article class="glass card">
        <h2>Quick context</h2>
        <p><strong>Location:</strong> {profileHighlights.location}</p>
        <p><strong>Experience:</strong> {profileHighlights.yearsExperience}</p>
        <p><strong>Public repos:</strong> {profileHighlights.repoCount}+</p>
        <p>
          <strong>GitHub:</strong>
          <a href="https://github.com/Zettersten" target="_blank" rel="noreferrer"
            >github.com/Zettersten</a
          >
        </p>
      </article>
    </section>

    <section class="glass card milestones">
      <h2>Selected milestones</h2>
      <ul>
        {linkedinHighlights.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="timeline" aria-label="Personal and career timeline">
      <article class="moment glass">
        <img src="/images/erik-usbank-team.jpg" alt="Erik with US Bank team" loading="lazy" />
        <div>
          <h3>US Bank years</h3>
          <p>Leadership under pressure, high reliability standards, and scale discipline.</p>
        </div>
      </article>

      <article class="moment glass">
        <img src="/images/erik-ets-office.jpg" alt="Erik in office at ETS" loading="lazy" />
        <div>
          <h3>ETS chapter</h3>
          <p>Fintech foundations: payment infrastructure, product velocity, and execution grit.</p>
        </div>
      </article>

      <article class="moment glass">
        <img src="/images/erik-mustache.jpg" alt="Erik with mustache" loading="lazy" />
        <div>
          <h3>Builder energy</h3>
          <p>Different look, same obsession: shipping useful systems that hold up in production.</p>
        </div>
      </article>

      <article class="moment glass">
        <img src="/images/erik-brother.jpg" alt="Erik with his older brother" loading="lazy" />
        <div>
          <h3>Family roots</h3>
          <p>Perspective, loyalty, and where my work ethic was actually forged.</p>
        </div>
      </article>

      <article class="moment glass">
        <img src="/images/erik-first-baby.jpg" alt="Erik with first baby" loading="lazy" />
        <div>
          <h3>First baby</h3>
          <p>A reminder that ambition is best when anchored to people who matter most.</p>
        </div>
      </article>

      <article class="moment glass">
        <img src="/images/erik-wendy.jpg" alt="Erik with Wendy" loading="lazy" />
        <div>
          <h3>Wendy</h3>
          <p>The personal side of the story: partnership, grounding, and long-term perspective.</p>
        </div>
      </article>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }
  .intro {
    max-width: 860px;
  }

  .top-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }
  .card {
    padding: 0.95rem;
    border-radius: 16px;
  }
  .card h2 {
    margin: 0 0 0.45rem;
    font-size: 1.2rem;
  }
  .card p {
    margin: 0.32rem 0;
    line-height: 1.6;
  }
  .card a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .card ul {
    margin: 0;
    padding-left: 1rem;
  }
  .card li {
    margin: 0.35rem 0;
    line-height: 1.58;
  }

  .milestones {
    margin-top: 0.8rem;
  }

  .timeline {
    margin-top: 0.8rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }
  .moment {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 0.65rem;
    align-items: start;
    padding: 0.55rem;
    border-radius: 14px;
  }
  .moment img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 9px;
    border: 1px solid #d7d7d7;
  }
  .moment h3 {
    margin: 0 0 0.2rem;
    font-size: 1.02rem;
  }
  .moment p {
    margin: 0;
    color: #555;
    line-height: 1.55;
    font-size: 0.93rem;
  }

  @media (max-width: 980px) {
    .top-grid,
    .timeline {
      grid-template-columns: 1fr;
    }
    .moment {
      grid-template-columns: 1fr;
    }
    .moment img {
      height: 220px;
    }
  }
</style>
