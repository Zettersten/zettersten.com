---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights, linkedinHighlights } from '../data/projects';
---

<BaseLayout
  title="About Erik Zettersten"
  description="Background, operating style, and leadership approach from Erik Zettersten."
  image="/images/erik-home.jpg"
>
  <Nav />
  <main id="main-content" class="container page">
    <header class="intro">
      <p class="kicker">About</p>
      <h1>I’m an operator who likes unfinished systems and hard problems.</h1>
      <p class="lead muted">
        I’ve spent my career building in moments where the map doesn’t exist yet: fintech,
        blockchain, AI platforms, and mission-critical data systems. The work is messy, but that’s
        where leverage lives.
      </p>
    </header>

    <section class="grid">
      <article class="glass card span-2">
        <h2>What I optimize for</h2>
        <ul>
          <li>Clear decision-making over endless alignment theater.</li>
          <li>Reliable systems over flashy demos.</li>
          <li>Shipped outcomes over roadmap storytelling.</li>
          <li>Teams that can execute under pressure without burning out.</li>
        </ul>
      </article>

      <article class="glass card profile">
        <img src="/images/erik-home.jpg" alt="Erik Zettersten" loading="lazy" />
        <p class="muted">{profileHighlights.location}</p>
      </article>

      <article class="glass card span-2">
        <h2>Selected milestones</h2>
        <ul>
          {linkedinHighlights.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="glass card">
        <h2>Quick context</h2>
        <p><strong>Experience:</strong> {profileHighlights.yearsExperience}</p>
        <p><strong>Public repos:</strong> {profileHighlights.repoCount}+</p>
        <p>
          <strong>GitHub:</strong>
          <a href="https://github.com/Zettersten" target="_blank" rel="noreferrer"
            >github.com/Zettersten</a
          >
        </p>
      </article>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1100px;
    padding-top: 1.8rem;
    padding-bottom: 2rem;
  }
  .intro {
    max-width: 80ch;
    margin-bottom: 1rem;
  }
  h1 {
    margin: 0.35rem 0 0.7rem;
    font-size: clamp(2.1rem, 5.2vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
  }
  .lead {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.72;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    align-items: start;
  }
  .card {
    padding: 1rem;
    border-radius: 18px;
  }
  .span-2 {
    grid-column: span 2;
  }

  .card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }
  .card p {
    margin: 0.35rem 0;
    line-height: 1.6;
  }
  .card a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .card ul {
    margin: 0;
    padding-left: 1rem;
  }
  .card li {
    margin: 0.38rem 0;
    line-height: 1.6;
  }

  .profile img {
    width: 100%;
    border-radius: 12px;
    border: 1px solid #d7d7d7;
    margin-bottom: 0.4rem;
  }

  @media (max-width: 980px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .span-2 {
      grid-column: span 1;
    }
  }
</style>
