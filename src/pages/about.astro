---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights, linkedinHighlights } from '../data/projects';
---

<BaseLayout
  title="About Erik Zettersten"
  description="Background, operating style, and leadership approach from Erik Zettersten."
  image="/images/erik-home.jpg"
>
  <Nav />
  <main id="main-content" class="container page page-shell">
    <header class="intro page-hero">
      <p class="kicker">About</p>
      <h1 class="page-title">I’m an operator who likes unfinished systems and hard problems.</h1>
      <p class="lead page-subtitle">
        I’ve spent my career building in moments where the map doesn’t exist yet: fintech,
        blockchain, AI platforms, and mission-critical data systems. The work is messy, but that’s
        where leverage lives.
      </p>
    </header>

    <section class="grid">
      <article class="glass card span-2">
        <h2>What I optimize for</h2>
        <ul>
          <li>Clear decision-making over endless alignment theater.</li>
          <li>Reliable systems over flashy demos.</li>
          <li>Shipped outcomes over roadmap storytelling.</li>
          <li>Teams that can execute under pressure without burning out.</li>
        </ul>
      </article>

      <article class="glass card">
        <h2>Quick context</h2>
        <p><strong>Location:</strong> {profileHighlights.location}</p>
        <p><strong>Experience:</strong> {profileHighlights.yearsExperience}</p>
        <p><strong>Public repos:</strong> {profileHighlights.repoCount}+</p>
        <p>
          <strong>GitHub:</strong>
          <a href="https://github.com/Zettersten" target="_blank" rel="noreferrer"
            >github.com/Zettersten</a
          >
        </p>
      </article>

      <article class="glass card span-3">
        <h2>Selected milestones</h2>
        <ul>
          {linkedinHighlights.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="glass card span-3">
        <h2>Personal snapshots</h2>
        <div class="gallery">
          <figure>
            <img
              src="/images/erik-usbank-team.jpg"
              alt="Erik with US Bank team"
              loading="lazy"
            /><figcaption>US Bank team</figcaption>
          </figure>
          <figure>
            <img
              src="/images/erik-wendy.jpg"
              alt="Erik married to Wendy"
              loading="lazy"
            /><figcaption>Married to Wendy</figcaption>
          </figure>
          <figure>
            <img
              src="/images/erik-ets-office.jpg"
              alt="Erik in office at ETS"
              loading="lazy"
            /><figcaption>Office days at ETS</figcaption>
          </figure>
          <figure>
            <img
              src="/images/erik-mustache.jpg"
              alt="Erik with mustache"
              loading="lazy"
            /><figcaption>Mustache era</figcaption>
          </figure>
          <figure>
            <img
              src="/images/erik-brother.jpg"
              alt="Erik with his older brother"
              loading="lazy"
            /><figcaption>With my older brother</figcaption>
          </figure>
          <figure>
            <img
              src="/images/erik-first-baby.jpg"
              alt="Erik with first baby"
              loading="lazy"
            /><figcaption>First baby</figcaption>
          </figure>
        </div>
      </article>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }
  .intro {
    max-width: 860px;
  }
  .lead {
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    align-items: start;
  }
  .card {
    padding: 1rem;
    border-radius: 18px;
  }
  .span-2 {
    grid-column: span 2;
  }
  .span-3 {
    grid-column: span 3;
  }

  .card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }
  .card p {
    margin: 0.35rem 0;
    line-height: 1.6;
  }
  .card a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .card ul {
    margin: 0;
    padding-left: 1rem;
  }
  .card li {
    margin: 0.38rem 0;
    line-height: 1.6;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
  }
  .gallery figure {
    margin: 0;
  }
  .gallery img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid #d7d7d7;
    display: block;
  }
  .gallery figcaption {
    font-size: 0.82rem;
    color: #666;
    margin-top: 0.22rem;
  }

  @media (max-width: 980px) {
    .grid,
    .gallery {
      grid-template-columns: 1fr;
    }
    .span-2,
    .span-3 {
      grid-column: span 1;
    }
    .gallery img {
      height: 220px;
    }
  }
</style>
