---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights, linkedinHighlights } from '../data/projects';
---

<BaseLayout title="About Erik Zettersten">
  <Nav />
  <main class="container page">
    <p class="kicker">About</p>
    <h1>Tech leader. Product instigator. Professional shipper of hard things.</h1>
    <p class="muted lead">
      Erik Zettersten makes complex products feel obvious. He blends strategy, engineering,
      and operator-level execution to get real outcomes fast.
    </p>

    <section class="glass block">
      <h2>The quick origin story</h2>
      <ul>
        {linkedinHighlights.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="glass block">
      <h2>How Erik works (aka the no-BS playbook)</h2>
      <ul>
        <li>Start with outcomes. Fancy features come later.</li>
        <li>Build for speed and reliability, not heroic firefighting.</li>
        <li>Keep product, design, and engineering in the same room.</li>
        <li>Ship, learn, level up, repeat.</li>
      </ul>
    </section>

    <section class="glass photo">
      <img src="https://msdynamicsworld.com/sites/default/files/pictures/thumbnail_erik.jpg" alt="Erik Zettersten portrait" loading="lazy" />
    </section>

    <section class="meta muted">
      <span>{profileHighlights.location}</span>
      <span>•</span>
      <span>{profileHighlights.repoCount}+ repositories</span>
      <span>•</span>
      <a href="https://github.com/Zettersten" target="_blank" rel="noreferrer">github.com/Zettersten</a>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page { padding-top: 4.2rem; max-width: 880px; }
  .kicker { margin: 0; text-transform: uppercase; letter-spacing: .07em; color: var(--brand); font-size: .75rem; font-weight: 700; }
  h1 { font-size: clamp(2rem, 7vw, 4.6rem); line-height: .98; letter-spacing: -.03em; margin: .4rem 0 1rem; }
  .lead { font-size: clamp(1rem, 2vw, 1.3rem); max-width: 66ch; }
  .block { margin-top: 2rem; padding: 1.2rem; }
  .block h2 { margin: 0 0 .5rem; font-size: 1.25rem; }
  .block ul { margin: 0; padding-left: 1rem; }
  .block li { margin: .4rem 0; }
  .photo { margin-top: 1.5rem; padding: .4rem; max-width: 360px; }
  .photo img { display:block; width:100%; height:auto; filter: grayscale(100%) contrast(115%); }
  .meta { margin-top: 1.5rem; display: flex; gap: .5rem; flex-wrap: wrap; }
</style>