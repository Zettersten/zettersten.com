---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights, linkedinHighlights } from '../data/projects';
---

<BaseLayout title="About Erik Zettersten">
  <Nav />
  <main class="container page">
    <p class="kicker">About</p>
    <h1>Erik Zettersten is a technology executive who turns complexity into execution.</h1>
    <p class="muted lead">
      He operates at the intersection of AI strategy, engineering systems, and business outcomes.
      The throughline across his work: reduce noise, align teams, and ship solutions people trust.
    </p>

    <section class="glass block">
      <h2>The quick origin story</h2>
      <ul>
        {linkedinHighlights.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="glass block">
      <h2>How Erik creates leverage</h2>
      <ul>
        <li>Translate business goals into technical operating plans.</li>
        <li>Design systems that balance speed, reliability, and governance.</li>
        <li>Align product, engineering, and leadership around one decision model.</li>
        <li>Build repeatable execution engines, not one-off heroics.</li>
      </ul>
    </section>

    <section class="glass photo">
      <img
        src="https://msdynamicsworld.com/sites/default/files/pictures/thumbnail_erik.jpg"
        alt="Erik Zettersten portrait"
        loading="lazy"
      />
    </section>

    <section class="meta muted">
      <span>{profileHighlights.location}</span>
      <span>•</span>
      <span>{profileHighlights.yearsExperience} in engineering leadership</span>
      <span>•</span>
      <span>{profileHighlights.repoCount}+ repositories</span>
      <span>•</span>
      <a href="https://github.com/Zettersten" target="_blank" rel="noreferrer"
        >github.com/Zettersten</a
      >
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    padding-top: 4.2rem;
    max-width: 880px;
  }
  h1 {
    font-size: clamp(2rem, 7vw, 4.6rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin: 0.4rem 0 1rem;
  }
  .lead {
    font-size: clamp(1rem, 2vw, 1.3rem);
    max-width: 66ch;
  }
  .block {
    margin-top: 2rem;
    padding: 1.2rem;
  }
  .block h2 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }
  .block ul {
    margin: 0;
    padding-left: 1rem;
  }
  .block li {
    margin: 0.4rem 0;
  }
  .photo {
    margin-top: 1.5rem;
    padding: 0.4rem;
    max-width: 360px;
  }
  .photo img {
    display: block;
    width: 100%;
    height: auto;
    filter: grayscale(100%) contrast(115%);
  }
  .meta {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
