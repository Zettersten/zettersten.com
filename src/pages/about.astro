---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights, linkedinHighlights } from '../data/projects';
---

<BaseLayout
  title="About Erik Zettersten"
  description="Background, operating style, and leadership approach from Erik Zettersten."
  image="/og/about.svg"
>
  <Nav />
  <main id="main-content" class="container page page-shell">
    <header class="intro page-hero">
      <p class="kicker">About</p>
      <h1 class="page-title">I build leverage at inflection points.</h1>
      <p class="lead page-subtitle">
        I work where systems are changing fast and stakes are high: payments, platforms, AI, and
        mission-critical operations. My approach is direct—clarify the decision model, align the
        team, and ship work that holds up in production.
      </p>
    </header>

    <section class="grid">
      <article class="glass card span-2">
        <h2>Career highlights</h2>
        <ul>
          {linkedinHighlights.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="glass card">
        <h2>Core operating principles</h2>
        <ul>
          <li>Outcome clarity beats roadmap theater.</li>
          <li>Reliability is a product feature.</li>
          <li>Cross-functional alignment is an engineering problem too.</li>
          <li>Speed without standards creates expensive rework.</li>
        </ul>
      </article>

      <article class="glass card">
        <h2>Quick context</h2>
        <p><strong>Location:</strong> {profileHighlights.location}</p>
        <p><strong>Experience:</strong> {profileHighlights.yearsExperience}</p>
        <p><strong>Public work:</strong> {profileHighlights.repoCount}+ repositories</p>
        <p>
          <strong>GitHub:</strong>
          <a href="https://github.com/Zettersten" target="_blank" rel="noreferrer"
            >github.com/Zettersten</a
          >
        </p>
      </article>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }
  .intro {
    max-width: 860px;
  }
  .lead {
    margin: 0;
  }

  .grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    align-items: start;
  }
  .card {
    padding: 1rem;
    border-radius: 18px;
  }
  .span-2 {
    grid-column: span 2;
  }

  .card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }
  .card p {
    margin: 0.35rem 0;
    line-height: 1.6;
  }
  .card ul {
    margin: 0;
    padding-left: 1rem;
  }
  .card li {
    margin: 0.38rem 0;
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .span-2 {
      grid-column: span 1;
    }
  }
</style>
