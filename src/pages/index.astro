---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Erik Zettersten — AI Developer, Engineer, Strategist & Leader">
  <Nav />

  <main class="container">
    <section class="hero">
      <p class="eyebrow">AI Developer • Engineer • Strategist • Leader</p>
      <h1>Building practical AI systems that move business forward.</h1>
      <p class="muted intro">
        I'm Erik Zettersten — I design and ship high-impact software where product strategy,
        engineering craft, and AI execution intersect.
      </p>
      <div class="actions">
        <a class="btn primary" href="/work">See Selected Work</a>
        <a class="btn" href="/blog">Read the Blog</a>
      </div>
    </section>

    <section class="grid">
      <article class="glass card">
        <h3>AI Product Engineering</h3>
        <p class="muted">From concept to production: LLM workflows, orchestration, reliability, and UX.</p>
      </article>
      <article class="glass card">
        <h3>Systems + Platform Thinking</h3>
        <p class="muted">Architecting scalable systems with performance, maintainability, and speed in mind.</p>
      </article>
      <article class="glass card">
        <h3>Strategy + Leadership</h3>
        <p class="muted">Translating ambiguity into roadmaps, alignment, and measurable outcomes.</p>
      </article>
    </section>

    <section class="glass feature">
      <h2>What makes this different</h2>
      <p class="muted">
        This isn't a gallery of random projects. It's a focused narrative: how Erik helps teams
        build better products faster with AI-native engineering, strategic clarity, and leadership.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero { padding: 4.5rem 0 2.4rem; max-width: 820px; }
  .eyebrow { color: var(--brand); font-weight: 700; letter-spacing: .3px; margin: 0; }
  h1 {
    margin: .5rem 0 0;
    font-size: clamp(2rem, 6vw, 4.2rem);
    line-height: 1.04;
    letter-spacing: -.02em;
    max-width: 18ch;
  }
  .intro { font-size: 1.1rem; max-width: 65ch; margin-top: 1rem; }
  .actions { display: flex; gap: .8rem; margin-top: 1.4rem; flex-wrap: wrap; }

  .grid {
    margin-top: 1.7rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .card { padding: 1.15rem; }
  .card h3 { margin: 0 0 .35rem; font-size: 1.08rem; }
  .card p { margin: 0; }

  .feature { margin-top: 1.2rem; padding: 1.2rem; }
  .feature h2 { margin: 0 0 .2rem; font-size: 1.25rem; }
  .feature p { margin: 0; }

  @media (max-width: 920px){ .grid { grid-template-columns: 1fr; } }
</style>