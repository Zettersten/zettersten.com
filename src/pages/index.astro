---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { featuredProjects, profileHighlights } from '../data/projects';

const heroProjects = featuredProjects.slice(0, 3);
---

<BaseLayout title="Erik Zettersten — AI Developer, Engineer, Strategist & Leader">
  <Nav />

  <main class="container">
    <section class="hero">
      <div>
        <p class="eyebrow">{profileHighlights.role}</p>
        <h1>
          Erik Zettersten.
          <br />
          <span>Builds software systems where AI strategy meets engineering execution.</span>
        </h1>
        <p class="muted intro">
          I lead with product clarity, technical depth, and shipping velocity. My work spans AI-native
          architecture, developer tooling, and high-performance web systems.
        </p>
        <div class="actions">
          <a class="btn primary" href="/projects">Explore All Projects</a>
          <a class="btn" href="/blog">Read Musings</a>
        </div>
      </div>
      <figure class="portrait glass">
        <img src="https://msdynamicsworld.com/sites/default/files/pictures/thumbnail_erik.jpg" alt="Erik Zettersten" loading="eager" />
      </figure>
    </section>

    <section class="separation stat-band glass">
      <div><strong>{profileHighlights.repoCount}+</strong><span>Public repositories</span></div>
      <div><strong>{profileHighlights.followers}+</strong><span>GitHub followers</span></div>
      <div><strong>{profileHighlights.yearsExperience}</strong><span>Building software</span></div>
      <div><strong>{profileHighlights.location}</strong><span>Based in</span></div>
    </section>

    <section class="separation featured">
      <div class="section-head">
        <p class="kicker">Selected repositories</p>
        <h2>Proof of range, depth, and delivery.</h2>
      </div>
      <div class="cards">
        {heroProjects.map((project) => (
          <a class="glass card" href={project.url} target="_blank" rel="noreferrer">
            <small>{project.category}</small>
            <h3>{project.name}</h3>
            <p class="muted">{project.summary}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="separation mention glass">
      <p class="kicker">Around the internet</p>
      <h2>Featured in creator and strategy conversations.</h2>
      <p class="muted">Watch the feature on getting in touch with Gary Vee and how Erik approaches practical outreach with engineering-minded execution.</p>
      <p><a class="btn primary" href="/mentions">See mentions & media</a></p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero { padding: 6.4rem 0 1.8rem; display:grid; grid-template-columns: 1.2fr .8fr; gap: 1rem; align-items:start; }
  .eyebrow {
    color: var(--brand);
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    margin: 0 0 .8rem;
    font-size: .86rem;
  }
  h1 {
    margin: 0;
    font-family: 'Archivo', sans-serif;
    font-size: clamp(2.5rem, 10vw, 7rem);
    line-height: .92;
    letter-spacing: -0.04em;
    max-width: 12ch;
    text-transform: uppercase;
  }
  h1 span { color: #222; font-weight: 700; }
  .intro {
    margin-top: 1.3rem;
    font-size: clamp(1rem, 2.2vw, 1.45rem);
    max-width: 62ch;
    line-height: 1.5;
  }
  .actions { display: flex; gap: .85rem; margin-top: 2rem; flex-wrap: wrap; }

  .separation { margin-top: 4rem; }

  .stat-band {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: .75rem;
    padding: 1rem;
  }
  .stat-band div {
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1rem;
  }
  .stat-band strong { display: block; font-size: clamp(1.1rem, 2.4vw, 1.6rem); }
  .stat-band span { color: var(--muted); font-size: .92rem; }

  .section-head .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--brand);
    font-size: .75rem;
    font-weight: 700;
  }
  .section-head h2 {
    margin: .25rem 0 0;
    font-size: clamp(1.6rem, 5vw, 3.2rem);
    letter-spacing: -.02em;
    line-height: 1.03;
    max-width: 16ch;
  }

  .cards {
    margin-top: 1.25rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .card { padding: 1.2rem; min-height: 220px; }
  .card small { color: var(--brand); text-transform: uppercase; letter-spacing: .05em; font-weight: 700; }
  .card h3 { margin: .45rem 0 .4rem; font-size: 1.26rem; line-height: 1.2; }
  .card p { margin: 0; }

  .mention { padding: 1.1rem; }
  .mention h2 { margin: .25rem 0 .5rem; font-family: 'Archivo', sans-serif; font-size: clamp(1.5rem, 4vw, 2.6rem); line-height: .95; }

  .portrait { margin:0; padding: .4rem; }
  .portrait img { display:block; width:100%; height:auto; filter: grayscale(100%) contrast(115%); }

  @media (max-width: 980px) {
    .hero, .cards, .stat-band { grid-template-columns: 1fr; }
  }
</style>