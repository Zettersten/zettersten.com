---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights } from '../data/projects';
---

<BaseLayout
  title="Erik Zettersten — AI Developer, Engineer, Strategist & Leader"
  description="Erik Zettersten builds practical AI systems and leads teams that ship measurable outcomes."
  image="/images/erik-home.jpg"
>
  <Nav />

  <main id="main-content" class="container page page-shell">
    <section class="hero glass">
      <div class="hero-copy">
        <p class="kicker">Erik Zettersten</p>
        <h1 class="page-title">
          Building high-stakes systems where speed, trust, and execution all matter.
        </h1>
        <p class="page-subtitle">
          I help teams turn AI ambition into operational outcomes. My work sits at the intersection
          of strategy, engineering, and leadership execution.
        </p>

        <div class="cta-row">
          <a class="btn primary" href="/projects">See Projects</a>
          <a class="btn" href="/about">About Erik</a>
          <a class="btn" href="/blog">Read Articles</a>
        </div>
      </div>

      <figure class="hero-portrait">
        <img src="/images/erik-home.jpg" alt="Erik Zettersten portrait" loading="eager" />
      </figure>
    </section>

    <section class="proof" aria-label="Experience highlights">
      <article class="proof-card glass">
        <strong>{profileHighlights.yearsExperience}</strong>
        <span>Years engineering</span>
      </article>
      <article class="proof-card glass">
        <strong>{profileHighlights.repoCount}+</strong>
        <span>Repositories shipped</span>
      </article>
      <article class="proof-card glass">
        <strong>{profileHighlights.followers}+</strong>
        <span>Followers</span>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 0.9rem;
    padding: 0.9rem;
    border-radius: 22px;
  }

  .hero-copy {
    padding: 0.55rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .page-title {
    max-width: 14ch;
  }
  .page-subtitle {
    margin: 0;
    max-width: 56ch;
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.7;
  }

  .cta-row {
    margin-top: 1.05rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .hero-portrait {
    margin: 0;
    min-height: 380px;
  }
  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid #d6d6d6;
    display: block;
  }

  .proof {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }
  .proof-card {
    padding: 0.85rem;
    border-radius: 14px;
  }
  .proof-card strong {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 3vw, 2rem);
    line-height: 1;
  }
  .proof-card span {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.84rem;
    color: #606060;
  }

  @media (max-width: 980px) {
    .hero,
    .proof {
      grid-template-columns: 1fr;
    }
    .hero-portrait {
      min-height: 280px;
      max-height: 420px;
    }
  }
</style>
