---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights } from '../data/projects';
---

<BaseLayout
  title="Erik Zettersten — Product Engineer & Technology Leader"
  description="Erik Zettersten builds and ships production AI products, developer tools, and platform systems."
  image="/images/erik-home.jpg"
>
  <Nav />

  <main id="main-content" class="container page page-shell">
    <section class="hero glass">
      <div class="hero-copy">
        <p class="kicker">Erik Zettersten</p>
        <h1 class="page-title">I build production AI products people actually use.</h1>
        <p class="page-subtitle">
          Over 15+ years, I’ve shipped across fintech, media, and developer tooling — from hands-on
          engineering to leading teams responsible for delivery.
        </p>

        <div class="cta-row">
          <a class="btn primary" href="/projects">See Projects</a>
          <a class="btn" href="/work">Selected Work</a>
          <a class="btn" href="/about">About Erik</a>
        </div>

        <ul class="outcomes" aria-label="Selected outcomes">
          <li>
            <strong>55+ repositories</strong> spanning AI workflows, frontend systems, and tooling.
          </li>
          <li>
            <strong>Multiple sectors shipped:</strong> fintech, media, and government-adjacent systems.
          </li>
          <li>
            <strong>Public writing + case studies</strong> focused on practical implementation, not hype.
          </li>
        </ul>
      </div>

      <figure class="hero-portrait">
        <img src="/images/erik-home.jpg" alt="Erik Zettersten portrait" loading="eager" />
      </figure>
    </section>

    <section class="proof" aria-label="Experience highlights">
      <article class="proof-card glass">
        <strong>{profileHighlights.yearsExperience}</strong>
        <span>Years engineering</span>
      </article>
      <article class="proof-card glass">
        <strong>{profileHighlights.repoCount}+</strong>
        <span>Repositories shipped</span>
      </article>
      <article class="proof-card glass proof-card-domain">
        <strong>{profileHighlights.domains}</strong>
        <span>Primary operating domains</span>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 0.9rem;
    padding: 0.9rem;
    border-radius: 22px;
  }

  .hero-copy {
    padding: 0.55rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .page-title {
    max-width: 14ch;
  }
  .page-subtitle {
    margin: 0;
    max-width: 56ch;
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.7;
  }

  .cta-row {
    margin-top: 1.05rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .outcomes {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
    color: #333;
    display: grid;
    gap: 0.35rem;
    line-height: 1.55;
  }

  .outcomes strong {
    font-weight: 700;
  }

  .hero-portrait {
    margin: 0;
    min-height: 380px;
  }
  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid #d6d6d6;
    display: block;
  }

  .proof {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }
  .proof-card {
    padding: 0.85rem;
    border-radius: 14px;
  }
  .proof-card strong {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 3vw, 2rem);
    line-height: 1;
  }
  .proof-card span {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.84rem;
    color: #606060;
  }

  .proof-card-domain strong {
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    font-family: var(--font-sans);
    line-height: 1.2;
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .hero,
    .proof {
      grid-template-columns: 1fr;
    }
    .hero-portrait {
      min-height: 280px;
      max-height: 420px;
    }
  }
</style>
