---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { featuredProjects, profileHighlights } from '../data/projects';

const heroProjects = featuredProjects.slice(0, 3);
---

<BaseLayout title="Erik Zettersten — AI Developer, Engineer, Strategist & Leader">
  <Nav />

  <main class="container">
    <section class="hero">
      <div class="headline glass">
        <p class="eyebrow">{profileHighlights.role}</p>
        <h1>Engineering<br/>AI Strategy<br/>Into Reality.</h1>
        <p class="muted intro">
          Erik Zettersten builds high-leverage technology systems at the intersection of AI, product strategy,
          and execution. From developer infrastructure to customer-facing experiences, the focus is always outcomes.
        </p>
        <div class="actions">
          <a class="btn primary" href="/projects">Explore All Projects</a>
          <a class="btn" href="/mentions">Media + Mentions</a>
        </div>
      </div>

      <aside class="rail">
        <figure class="portrait glass">
          <img src="https://msdynamicsworld.com/sites/default/files/pictures/thumbnail_erik.jpg" alt="Erik Zettersten" loading="eager" />
        </figure>
        <div class="glass stat-band">
          <div><strong>{profileHighlights.repoCount}+</strong><span>Repositories</span></div>
          <div><strong>{profileHighlights.followers}+</strong><span>Followers</span></div>
          <div><strong>{profileHighlights.yearsExperience}</strong><span>Experience</span></div>
          <div><strong>{profileHighlights.location}</strong><span>Location</span></div>
        </div>
      </aside>
    </section>

    <section class="separation featured">
      <div class="section-head">
        <p class="kicker">Selected repositories</p>
        <h2>Built to perform, built to scale.</h2>
      </div>
      <div class="cards">
        {heroProjects.map((project) => (
          <a class="glass card" href={project.url} target="_blank" rel="noreferrer">
            <small>{project.category}</small>
            <h3>{project.name}</h3>
            <p class="muted">{project.summary}</p>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero { padding: 4rem 0 1.4rem; display:grid; grid-template-columns: 1.25fr .75fr; gap: 1rem; align-items:stretch; }
  .headline { padding: 2rem; position: relative; overflow: hidden; }
  .headline::after {
    content: '';
    position: absolute;
    width: 280px;
    height: 280px;
    right: -80px;
    bottom: -110px;
    background: radial-gradient(circle, rgba(179,255,59,.24), transparent 70%);
    pointer-events: none;
  }
  .eyebrow {
    color: var(--brand);
    font-weight: 800;
    letter-spacing: .11em;
    text-transform: uppercase;
    margin: 0 0 .8rem;
    font-size: .75rem;
  }
  h1 {
    margin: 0;
    font-family: 'Archivo', sans-serif;
    font-size: clamp(2.8rem, 10vw, 7rem);
    line-height: .86;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }
  .intro { margin-top: 1rem; font-size: clamp(1rem, 2vw, 1.25rem); max-width: 56ch; }
  .actions { display: flex; gap: .8rem; margin-top: 1.6rem; flex-wrap: wrap; }

  .rail { display: grid; gap: 1rem; }
  .portrait { margin: 0; padding: .5rem; }
  .portrait img { width: 100%; display:block; border-radius: calc(var(--radius) - 10px); filter: saturate(.9) contrast(1.05); }

  .stat-band { padding: 1rem; display:grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: .6rem; }
  .stat-band div { border: 1px solid var(--border); border-radius: 16px; padding: .8rem; background: rgba(255,255,255,.01); }
  .stat-band strong { display:block; font-family: 'Archivo', sans-serif; font-size: 1.15rem; }
  .stat-band span { color: var(--muted); font-size: .9rem; }

  .separation { margin-top: 3.5rem; }
  .section-head .kicker { margin: 0; text-transform: uppercase; letter-spacing: .08em; color: var(--brand); font-size: .73rem; font-weight: 800; }
  .section-head h2 {
    margin: .3rem 0 0;
    font-family: 'Archivo', sans-serif;
    font-size: clamp(1.8rem, 5vw, 3.6rem);
    line-height: .92;
    letter-spacing: -.03em;
    text-transform: uppercase;
  }

  .cards { margin-top: 1rem; display:grid; gap: 1rem; grid-template-columns: repeat(3,minmax(0,1fr)); }
  .card { padding: 1.2rem; min-height: 240px; transition: transform .16s ease, border-color .16s ease; }
  .card:hover { transform: translateY(-3px); border-color: var(--brand); }
  .card small { color: var(--brand); text-transform: uppercase; letter-spacing: .06em; font-weight: 800; }
  .card h3 { margin: .45rem 0 .4rem; font-size: 1.32rem; line-height: 1.1; font-family: 'Archivo', sans-serif; }
  .card p { margin: 0; }

  @media (max-width: 980px) {
    .hero, .cards { grid-template-columns: 1fr; }
  }
</style>