---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights } from '../data/projects';
---

<BaseLayout
  title="Erik Zettersten — AI Developer, Engineer, Strategist & Leader"
  description="Erik Zettersten builds practical AI systems and leads teams that ship measurable outcomes."
  image="/og/home.svg"
>
  <Nav />

  <main id="main-content" class="container page">
    <section class="hero glass">
      <div class="hero-copy">
        <p class="kicker">Erik Zettersten</p>
        <h1>Building high-stakes systems where speed, trust, and execution all matter.</h1>
        <p class="lead muted">
          I help teams turn AI ambition into operational outcomes. My work sits at the intersection
          of strategy, engineering, and leadership execution.
        </p>

        <div class="cta-row">
          <a class="btn primary" href="/projects">See Projects</a>
          <a class="btn" href="/about">About Erik</a>
          <a class="btn" href="/blog">Read Essays</a>
        </div>
      </div>

      <aside class="hero-stats" aria-label="Profile highlights">
        <article class="stat glass">
          <strong>{profileHighlights.repoCount}+</strong>
          <span>Repositories shipped</span>
        </article>
        <article class="stat glass">
          <strong>{profileHighlights.followers}+</strong>
          <span>Followers</span>
        </article>
        <article class="stat glass">
          <strong>{profileHighlights.yearsExperience}</strong>
          <span>Years engineering</span>
        </article>
      </aside>
    </section>

    <section class="value-grid">
      <article class="panel glass">
        <h2>Operator mindset</h2>
        <p class="muted">
          Less theater, more throughput. I focus on decisions that improve reliability, velocity,
          and business leverage at the same time.
        </p>
      </article>
      <article class="panel glass">
        <h2>Systems depth</h2>
        <p class="muted">
          From fintech pipelines to AI orchestration and enterprise governance, I build systems that
          survive production—not just demos.
        </p>
      </article>
      <article class="panel glass">
        <h2>Leadership under pressure</h2>
        <p class="muted">
          I align teams around clear constraints, measurable outcomes, and execution loops that keep
          momentum without sacrificing trust.
        </p>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page {
    padding-top: 1.4rem;
    padding-bottom: 2.2rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: 1rem;
    padding: 1.1rem;
    border-radius: 22px;
  }
  .hero-copy {
    padding: 0.8rem;
  }
  h1 {
    margin: 0.45rem 0 0.7rem;
    font-size: clamp(2.2rem, 6vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    max-width: 16ch;
  }
  .lead {
    margin: 0;
    max-width: 58ch;
    font-size: 1.03rem;
  }

  .cta-row {
    margin-top: 1.15rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hero-stats {
    display: grid;
    gap: 0.75rem;
    align-content: start;
  }
  .stat {
    border-radius: 16px;
    padding: 0.95rem;
  }
  .stat strong {
    display: block;
    font-size: clamp(1.8rem, 4vw, 2.3rem);
    line-height: 1;
    font-family: var(--font-serif);
  }
  .stat span {
    display: block;
    margin-top: 0.35rem;
    color: #616161;
    font-size: 0.86rem;
  }

  .value-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }
  .panel {
    border-radius: 18px;
    padding: 0.95rem;
  }
  .panel h2 {
    font-size: 1.22rem;
    margin: 0 0 0.35rem;
  }
  .panel p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .value-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
