---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profileHighlights } from '../data/projects';
---

<BaseLayout
  title="Erik Zettersten — AI Developer, Engineer, Strategist & Leader"
  description="Erik Zettersten builds practical AI systems and leads teams that ship measurable outcomes."
  image="/images/erik-home.jpg"
>
  <Nav />

  <main id="main-content" class="container page page-shell">
    <section class="hero glass">
      <div class="hero-copy">
        <p class="kicker">Erik Zettersten</p>
        <h1 class="page-title">
          Building high-stakes systems where speed, trust, and execution all matter.
        </h1>
        <p class="lead page-subtitle">
          I help teams turn AI ambition into operational outcomes. My work sits at the intersection
          of strategy, engineering, and leadership execution.
        </p>

        <div class="cta-row">
          <a class="btn primary" href="/projects">See Projects</a>
          <a class="btn" href="/about">About Erik</a>
          <a class="btn" href="/blog">Read Articles</a>
        </div>
      </div>

      <figure class="hero-portrait">
        <img src="/images/erik-home.jpg" alt="Erik Zettersten" loading="eager" />
      </figure>

      <aside class="hero-stats" aria-label="Profile highlights">
        <article class="stat glass">
          <strong>{profileHighlights.repoCount}+</strong>
          <span>Repositories shipped</span>
        </article>
        <article class="stat glass">
          <strong>{profileHighlights.followers}+</strong>
          <span>Followers</span>
        </article>
        <article class="stat glass">
          <strong>{profileHighlights.yearsExperience}</strong>
          <span>Years engineering</span>
        </article>
      </aside>
    </section>

    <section class="story-strip" aria-label="Personal highlights">
      <article class="strip-item glass">
        <img src="/images/erik-usbank-team.jpg" alt="Erik with US Bank team" loading="lazy" />
        <p>US Bank leadership chapter</p>
      </article>
      <article class="strip-item glass">
        <img src="/images/erik-ets-office.jpg" alt="Erik in office at ETS" loading="lazy" />
        <p>Building in the ETS days</p>
      </article>
      <article class="strip-item glass">
        <img src="/images/erik-wendy.jpg" alt="Erik with Wendy" loading="lazy" />
        <p>Life with Wendy</p>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.8fr 0.55fr;
    gap: 0.85rem;
    padding: 0.85rem;
    border-radius: 22px;
  }

  .hero-copy {
    padding: 0.6rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .page-title {
    max-width: 15ch;
  }
  .lead {
    margin: 0;
    max-width: 56ch;
    font-size: 1.03rem;
  }

  .cta-row {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .hero-portrait {
    margin: 0;
    min-height: 360px;
  }
  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid #d6d6d6;
  }

  .hero-stats {
    display: grid;
    gap: 0.65rem;
    align-content: start;
  }
  .stat {
    border-radius: 14px;
    padding: 0.8rem;
  }
  .stat strong {
    display: block;
    font-size: clamp(1.65rem, 3vw, 2rem);
    line-height: 1;
    font-family: var(--font-serif);
  }
  .stat span {
    display: block;
    margin-top: 0.28rem;
    color: #626262;
    font-size: 0.82rem;
  }

  .story-strip {
    margin-top: 0.85rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }
  .strip-item {
    margin: 0;
    padding: 0.42rem;
    border-radius: 14px;
  }
  .strip-item img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: 9px;
    border: 1px solid #d7d7d7;
    display: block;
  }
  .strip-item p {
    margin: 0.32rem 0.15rem 0.1rem;
    font-size: 0.83rem;
    color: #666;
  }

  @media (max-width: 1080px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-portrait {
      min-height: 300px;
      max-height: 420px;
    }
    .story-strip {
      grid-template-columns: 1fr;
    }
    .strip-item img {
      height: 210px;
    }
  }
</style>
