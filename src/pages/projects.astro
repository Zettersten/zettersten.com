---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { allProjects, contributionLinks } from '../data/all-projects';
---

<BaseLayout
  title="All Projects & Contributions — Erik Zettersten"
  description="A complete portfolio of Erik Zettersten's GitHub projects, contribution links, and project stories."
  image="/og/projects.svg"
>
  <Nav />
  <main id="main-content" class="container page page-shell">
    <header class="page-hero">
      <p class="kicker">Projects + Contributions</p>
      <h1 class="page-title">
        {allProjects.length} repositories, one operating pattern: ship useful systems.
      </h1>
      <p class="page-subtitle">
        Some are tools, some are platforms, some are experiments. All represent practical execution.
      </p>
      <div class="contrib glass">
        <a href={contributionLinks.profile} target="_blank" rel="noreferrer">Profile</a>
        <a href={contributionLinks.repositories} target="_blank" rel="noreferrer">Repositories</a>
        <a href={contributionLinks.activity} target="_blank" rel="noreferrer">Activity</a>
      </div>
    </header>

    <section class="grid" aria-label="All project cards">
      {
        allProjects.map((p) => (
          <article class="glass card">
            <div class="top">
              <h2>{p.name}</h2>
              <span class="lang">{p.language}</span>
            </div>
            <p class="story">{p.story}</p>
            {p.description && <p class="muted desc">{p.description}</p>}
            <div class="meta muted">
              ★ {p.stars} · Forks {p.forks}
            </div>
            <div class="links">
              <a class="btn" href={p.url} target="_blank" rel="noreferrer">
                GitHub Repo
              </a>
              {p.homepage && (
                <a class="btn" href={p.homepage} target="_blank" rel="noreferrer">
                  Live Site
                </a>
              )}
              {p.packages.map((pkg) => (
                <a class="btn" href={pkg.url} target="_blank" rel="noreferrer">
                  {pkg.manager} Package
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }
  .contrib {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    padding: 0.75rem;
    margin-top: 0.9rem;
    border-radius: 16px;
  }
  .contrib a {
    color: var(--text);
    font-weight: 600;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.45rem 0.7rem;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 1rem;
  }
  .card {
    padding: 0.95rem;
    border-radius: 18px;
  }
  .top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
  }
  .top h2 {
    margin: 0;
    font-size: 1.25rem;
  }
  .lang {
    color: var(--brand);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .story {
    margin: 0.45rem 0 0.35rem;
    line-height: 1.62;
  }
  .desc {
    margin: 0 0 0.45rem;
    line-height: 1.62;
  }
  .meta {
    font-size: 0.88rem;
  }
  .links {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    margin-top: 0.7rem;
  }

  @media (max-width: 980px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
