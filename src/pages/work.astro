---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { featuredProjects } from '../data/projects';
---

<BaseLayout title="Selected Work — Erik Zettersten">
  <Nav />
  <main class="container page">
    <header class="hero">
      <p class="kicker">Work</p>
      <h1>Proof Erik can ship: AI, tooling, performance, platforms.</h1>
      <p class="muted">Not theory. Not vibe decks. Real code, real products, real outcomes.</p>
      <p><a class="btn" href="/projects">Open the full vault</a></p>
    </header>

    <section class="list">
      {featuredProjects.map((item) => (
        <a class="glass row" href={item.url} target="_blank" rel="noreferrer">
          <small>{item.category}</small>
          <strong>{item.name}</strong>
          <p class="muted">{item.summary}</p>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page { padding-top: 4.2rem; }
  .hero { max-width: 920px; }
  .kicker { margin: 0; text-transform: uppercase; letter-spacing: .07em; color: var(--brand); font-size: .75rem; font-weight: 700; }
  h1 { margin: .45rem 0 .8rem; font-size: clamp(2rem, 7vw, 4.7rem); line-height: .98; letter-spacing: -.03em; }

  .list { display: grid; gap: 1rem; margin-top: 2rem; }
  .row { display: block; padding: 1.2rem; }
  .row small { color: var(--brand); text-transform: uppercase; letter-spacing: .05em; font-weight: 700; }
  .row strong { display: block; font-size: 1.22rem; margin-top: .4rem; }
  .row p { margin: .4rem 0 0; max-width: 90ch; }
</style>