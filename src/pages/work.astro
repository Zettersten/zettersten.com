---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { featuredProjects } from '../data/projects';
---

<BaseLayout
  title="Selected Work — Erik Zettersten"
  description="A curated set of shipped projects across AI, platforms, and product engineering."
  image="/og/work.svg"
>
  <Nav />
  <main id="main-content" class="container page page-shell">
    <header class="page-hero">
      <p class="kicker">Work</p>
      <h1 class="page-title">
        Selected builds across AI workflows, platform tooling, and product engineering.
      </h1>
      <p class="page-subtitle">Each entry links directly to shipped code, not pitch language.</p>
      <p><a class="btn" href="/projects">Open the full project index</a></p>
    </header>

    <section class="list" aria-label="Selected work list">
      {
        featuredProjects.map((item) => (
          <a class="glass row" href={item.url} target="_blank" rel="noreferrer">
            <small>{item.category}</small>
            <strong>{item.name}</strong>
            <p class="muted">{item.summary}</p>
          </a>
        ))
      }
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }

  .list {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
  }
  .row {
    display: block;
    padding: 1rem;
    border-radius: 18px;
  }
  .row small {
    color: var(--brand);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }
  .row strong {
    display: block;
    font-size: 1.22rem;
    margin-top: 0.35rem;
    font-family: var(--font-serif);
  }
  .row p {
    margin: 0.35rem 0 0;
    max-width: 85ch;
    line-height: 1.65;
  }
</style>
