---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { getCollection } from 'astro:content';
import { compareBlogPostsByDateThenTitle } from '../../utils/blog';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  compareBlogPostsByDateThenTitle,
);
const [featured, ...restPosts] = posts;

const blogCollectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog — Erik Zettersten',
  about: 'AI, strategy, systems, and leadership essays',
};
---

<BaseLayout
  title="Blog — Erik Zettersten"
  description="Opinionated long-form essays on AI, strategy, systems, and leadership."
  image="/og/blog.svg"
  jsonLd={blogCollectionJsonLd}
>
  <Nav />
  <main id="main-content" class="container page">
    <header class="hero">
      <div>
        <p class="kicker">Journal</p>
        <h1>Essays with strong opinions and practical depth.</h1>
        <p class="muted intro">
          Long-form writing on AI, leadership, systems, and execution. Less trend-chasing. More real
          tradeoffs.
        </p>
      </div>
      <BlogSearch />
    </header>

    {
      featured && (
        <section class="featured glass" aria-label="Featured article">
          {featured.data.coverImage && (
            <img src={featured.data.coverImage} alt={featured.data.title} loading="eager" />
          )}
          <div class="featured-copy">
            <p class="cat">Featured · {featured.data.category}</p>
            <h2>
              <a href={`/blog/${featured.id.replace(/\.mdx?$/, '')}/`}>{featured.data.title}</a>
            </h2>
            <p class="muted">
              {featured.data.date.toLocaleDateString('en-US', {
                month: 'long',
                day: 'numeric',
                year: 'numeric',
              })}
              {' · '}Erik Zettersten
            </p>
            <p class="desc">{featured.data.description}</p>
            <a class="read" href={`/blog/${featured.id.replace(/\.mdx?$/, '')}/`}>
              Read featured article →
            </a>
          </div>
        </section>
      )
    }

    <section class="feed" aria-label="Blog post list">
      {
        restPosts.map((post) => (
          <article class="entry glass">
            {post.data.coverImage && (
              <a
                href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}
                class="thumb-wrap"
                aria-label={`Read ${post.data.title}`}
              >
                <img
                  class="thumb"
                  src={post.data.coverImage}
                  alt={post.data.title}
                  loading="lazy"
                />
              </a>
            )}
            <div class="copy">
              <p class="cat">{post.data.category}</p>
              <h3>
                <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}>{post.data.title}</a>
              </h3>
              <p class="meta muted">
                {post.data.date.toLocaleDateString('en-US', {
                  month: 'long',
                  day: 'numeric',
                  year: 'numeric',
                })}
              </p>
              <p class="desc">{post.data.description}</p>
              <a class="read" href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}>
                Read article →
              </a>
            </div>
          </article>
        ))
      }
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1080px;
    padding-top: 1.7rem;
    padding-bottom: 2.1rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 390px);
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }
  h1 {
    margin: 0.35rem 0 0.45rem;
    font-size: clamp(2.1rem, 5.4vw, 3.7rem);
    line-height: 0.97;
    letter-spacing: -0.02em;
    max-width: 18ch;
  }
  .intro {
    margin: 0;
    max-width: 62ch;
  }

  .featured {
    display: grid;
    grid-template-columns: 42% 1fr;
    gap: 1rem;
    padding: 0.9rem;
    border-radius: 20px;
    margin-bottom: 0.9rem;
  }
  .featured img {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid #d7d7d7;
  }
  .featured-copy {
    padding: 0.35rem 0.2rem;
  }

  .cat {
    margin: 0 0 0.35rem;
    color: #696969;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.69rem;
  }
  h2,
  h3 {
    margin: 0;
    font-family: var(--font-serif);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  h2 {
    font-size: clamp(1.6rem, 3.2vw, 2.3rem);
  }
  h3 {
    font-size: clamp(1.25rem, 2.4vw, 1.65rem);
  }

  .feed {
    display: grid;
    gap: 0.8rem;
  }
  .entry {
    border-radius: 16px;
    padding: 0.72rem;
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 0.85rem;
  }
  .thumb {
    width: 100%;
    height: 170px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid #d7d7d7;
  }
  .copy {
    padding: 0.15rem;
  }
  .meta {
    margin: 0.42rem 0;
    font-size: 0.84rem;
  }
  .desc {
    margin: 0.2rem 0 0.55rem;
    color: #262626;
    line-height: 1.58;
  }
  .read {
    font-size: 0.88rem;
    font-weight: 500;
    color: #222;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 940px) {
    .hero,
    .featured,
    .entry {
      grid-template-columns: 1fr;
    }
    .thumb {
      height: 210px;
    }
  }
</style>
