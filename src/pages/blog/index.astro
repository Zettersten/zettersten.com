---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title="Blog — Erik Zettersten" description="Clean, practical essays on AI, strategy, systems, and leadership.">
  <Nav />
  <main class="container page">
    <header class="hero">
      <div>
        <p class="kicker">Journal</p>
        <h1>Sharp thinking,<br />clean execution.</h1>
        <p class="muted">Long-form essays on AI, leadership, systems, and market reality. No fluff. No trend cosplay.</p>
      </div>
      <BlogSearch />
    </header>

    <section class="feed">
      {posts.map((post) => (
        <article class="entry">
          {post.data.coverImage && (
            <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`} class="thumb-wrap">
              <img class="thumb" src={post.data.coverImage} alt={post.data.title} loading="lazy" />
            </a>
          )}
          <div class="copy">
            <p class="cat">{post.data.category}</p>
            <h2><a href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}>{post.data.title}</a></h2>
            <p class="meta muted">
              <span>Erik Zettersten</span>
              <span>•</span>
              <span>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            </p>
            <p class="muted desc">{post.data.description}</p>
            <a class="read" href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}>Read article</a>
          </div>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page { max-width: 1040px; padding-top: 2.6rem; }
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1.5rem;
  }
  .kicker { margin: 0; font-size: .74rem; letter-spacing: .08em; text-transform: uppercase; color: #666; }
  h1 { margin: .3rem 0 .45rem; font-size: clamp(2.2rem, 7vw, 5rem); line-height: .92; font-weight: 550; letter-spacing: -.03em; }
  .hero p { max-width: 56ch; }

  .feed { display: grid; gap: 1.6rem; }
  .entry {
    border-top: 1px solid var(--line);
    padding-top: 1.35rem;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 1rem;
    align-items: start;
  }
  .thumb-wrap { display: block; }
  .thumb {
    width: 100%;
    height: 210px;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid #d2d2d2;
  }
  .cat { margin: .1rem 0 .35rem; color: #666; text-transform: uppercase; letter-spacing: .07em; font-size: .72rem; }
  h2 { margin: 0; font-size: clamp(1.45rem, 3vw, 2.1rem); line-height: 1.08; font-weight: 600; }
  .meta { margin: .45rem 0; font-size: .88rem; display: flex; gap: .4rem; flex-wrap: wrap; }
  .desc { margin: .2rem 0 .65rem; max-width: 60ch; }
  .read { font-size: .9rem; text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
    .entry { grid-template-columns: 1fr; }
    .thumb { height: 220px; }
  }
</style>