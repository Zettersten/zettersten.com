---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { getCollection } from 'astro:content';
import { compareBlogPostsByDateThenTitle } from '../../utils/blog';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  compareBlogPostsByDateThenTitle,
);
const [featured, ...restPosts] = posts;

const blogCollectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog — Erik Zettersten',
  about: 'AI, strategy, systems, and leadership articles',
};
---

<BaseLayout
  title="Blog — Erik Zettersten"
  description="Opinionated long-form articles on AI, strategy, systems, and leadership."
  image="/og/blog.svg"
  jsonLd={blogCollectionJsonLd}
>
  <Nav />
  <main id="main-content" class="container page page-shell">
    <header class="hero-head">
      <div>
        <p class="kicker">Journal</p>
        <h1>Recent Articles</h1>
        <p class="muted intro">
          Strong opinions, practical details, and real implementation context.
        </p>
      </div>
      <BlogSearch />
    </header>

    {
      featured && (
        <section class="featured glass" aria-label="Featured article">
          {featured.data.coverImage && (
            <img src={featured.data.coverImage} alt={featured.data.title} loading="eager" />
          )}
          <div class="featured-copy">
            <p class="meta-row">
              <span class="pill">Featured</span>
              <span class="muted">
                {Math.max(4, Math.round(featured.body.split(/\s+/).length / 220))} min read
              </span>
            </p>
            <h2>
              <a href={`/blog/${featured.id.replace(/\.mdx?$/, '')}/`}>{featured.data.title}</a>
            </h2>
            <p class="desc">{featured.data.description}</p>
            <a class="read" href={`/blog/${featured.id.replace(/\.mdx?$/, '')}/`}>
              Read More →
            </a>
          </div>
        </section>
      )
    }

    <section class="recent-head">
      <h3>Our Recent Articles</h3>
    </section>

    <section class="cards" aria-label="Recent articles">
      {
        restPosts.map((post) => (
          <article class="card glass">
            {post.data.coverImage && (
              <img src={post.data.coverImage} alt={post.data.title} loading="lazy" />
            )}
            <div class="card-copy">
              <p class="muted small">
                Erik Zettersten ·{' '}
                {post.data.date.toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                  year: 'numeric',
                })}
              </p>
              <h4>
                <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}>{post.data.title}</a>
              </h4>
              <p class="muted excerpt">{post.data.description}</p>
              <a class="read" href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}>
                Read More →
              </a>
            </div>
          </article>
        ))
      }
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }

  .hero-head {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 390px);
    gap: 1rem;
    align-items: end;
    margin-bottom: 0.95rem;
  }
  h1 {
    margin: 0.35rem 0 0.45rem;
    font-size: clamp(2rem, 5vw, 3.3rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
  }
  .intro {
    margin: 0;
  }

  .featured {
    display: grid;
    grid-template-columns: 44% 1fr;
    gap: 0.95rem;
    padding: 0.85rem;
    border-radius: 20px;
  }
  .featured img {
    width: 100%;
    min-height: 250px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid #d7d7d7;
  }
  .featured-copy {
    padding: 0.3rem 0.15rem;
  }
  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.45rem;
  }
  .pill {
    font-size: 0.72rem;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: #e9eefb;
    color: #3759d5;
    border: 1px solid #ccd8ff;
    font-weight: 600;
  }
  h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    line-height: 1.06;
  }
  .desc {
    margin: 0.55rem 0 0.65rem;
    line-height: 1.65;
    color: #2a2a2a;
  }

  .recent-head {
    margin: 1rem 0 0.6rem;
  }
  .recent-head h3 {
    margin: 0;
    font-size: 1.85rem;
    font-family: var(--font-serif);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }
  .card {
    border-radius: 16px;
    overflow: hidden;
  }
  .card img {
    width: 100%;
    height: 175px;
    object-fit: cover;
    border-bottom: 1px solid #d8d8d8;
  }
  .card-copy {
    padding: 0.75rem;
  }
  .small {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.4;
  }
  h4 {
    margin: 0.42rem 0 0.42rem;
    font-size: 1.2rem;
    line-height: 1.2;
  }
  .excerpt {
    margin: 0;
    line-height: 1.55;
    font-size: 0.92rem;
  }
  .read {
    display: inline-block;
    margin-top: 0.55rem;
    font-size: 0.86rem;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 980px) {
    .hero-head,
    .featured,
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
