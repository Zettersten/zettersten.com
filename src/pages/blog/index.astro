---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { getCollection } from 'astro:content';
import { compareBlogPostsByDateThenTitle } from '../../utils/blog';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(compareBlogPostsByDateThenTitle);
---

<BaseLayout title="Blog — Erik Zettersten" description="Clean, practical essays on AI, strategy, systems, and leadership.">
  <Nav />
  <main class="container page">
    <header class="hero">
      <div>
        <p class="kicker">Journal</p>
        <h1>Long-form essays that actually say something.</h1>
        <p class="muted intro">Opinionated writing on AI, leadership, and systems work — with context, examples, and receipts.</p>
      </div>
      <BlogSearch />
    </header>

    <section class="feed" aria-label="Blog post list">
      {posts.map((post) => (
        <article class="entry glass">
          {post.data.coverImage && (
            <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`} class="thumb-wrap" aria-label={`Read ${post.data.title}`}>
              <img class="thumb" src={post.data.coverImage} alt={post.data.title} loading="lazy" />
            </a>
          )}
          <div class="copy">
            <p class="cat">{post.data.category}</p>
            <h2><a href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}>{post.data.title}</a></h2>
            <p class="meta muted">
              <span>Erik Zettersten</span>
              <span>•</span>
              <span>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            </p>
            <p class="desc">{post.data.description}</p>

            <div class="tags">
              {post.data.tags?.slice(0, 3).map((tag) => <span>{tag}</span>)}
            </div>

            <a class="read" href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}>
              Read article →
            </a>
          </div>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page { max-width: 1060px; padding-top: 2.3rem; }

  .hero {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 390px);
    gap: 1rem;
    align-items: end;
    margin-bottom: 1.25rem;
  }
  .kicker {
    margin: 0;
    font-size: .72rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #707070;
  }
  h1 {
    margin: .35rem 0 .4rem;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5.5vw, 3.55rem);
    line-height: .98;
    letter-spacing: -.01em;
  }
  .intro { max-width: 62ch; margin: 0; }

  .feed { display: grid; gap: 1rem; }
  .entry {
    border-radius: 18px;
    padding: .85rem;
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 1rem;
  }

  .thumb-wrap { display: block; }
  .thumb {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid #d7d7d7;
  }

  .copy { padding: .2rem .15rem; }
  .cat {
    margin: 0 0 .32rem;
    color: #686868;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .7rem;
  }
  h2 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.3vw, 1.9rem);
    line-height: 1.12;
  }
  h2 a { text-decoration: none; }
  h2 a:hover { text-decoration: underline; text-underline-offset: 4px; }

  .meta {
    margin: .5rem 0;
    font-size: .84rem;
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
  }
  .desc {
    margin: .2rem 0 .6rem;
    color: #262626;
    line-height: 1.6;
    max-width: 65ch;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    margin-bottom: .65rem;
  }
  .tags span {
    font-size: .73rem;
    color: #575757;
    border: 1px solid #d4d4d4;
    border-radius: 999px;
    padding: .18rem .55rem;
    background: #f3f3f3;
  }

  .read {
    font-size: .88rem;
    font-weight: 500;
    color: #222;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 940px) {
    .hero { grid-template-columns: 1fr; }
    .entry { grid-template-columns: 1fr; }
    .thumb { height: 220px; }
  }
</style>
