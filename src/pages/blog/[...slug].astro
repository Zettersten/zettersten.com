---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id.replace(/\.mdx?$/, '') }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const estimateReadingMinutes = Math.max(4, Math.round(post.body.split(/\s+/).length / 220));

const hash = [...post.id].reduce((acc: number, c: string) => acc + c.charCodeAt(0), 0);
const bars = Array.from({ length: 6 }).map((_, i) => 18 + ((hash + i * 17) % 52));
---

<BaseLayout title={`${post.data.title} — Erik Zettersten`} description={post.data.description} image={post.data.coverImage || '/og-default.svg'}>
  <Nav />
  <main class="container article-wrap">
    <a href="/blog" class="muted back">← Back to journal</a>

    <header class="article-head">
      <p class="cat">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="sub muted">{post.data.description}</p>
      <p class="meta muted">
        <span>Erik Zettersten</span>
        <span>•</span>
        <span>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
        <span>•</span>
        <span>{estimateReadingMinutes} min read</span>
      </p>
    </header>

    {post.data.coverImage && (
      <figure class="hero-media">
        <img src={post.data.coverImage} alt={post.data.title} loading="eager" />
      </figure>
    )}

    <section class="content-grid">
      <article class="prose">
        <Content />
      </article>

      <aside class="side glass">
        <div>
          <p class="side-k">Quick map</p>
          <ul>
            {headings.slice(0, 5).map((h: { text: string }) => <li>{h.text}</li>)}
          </ul>
        </div>

        <div class="chart-wrap">
          <p class="side-k">Signal chart</p>
          <svg viewBox="0 0 220 90" aria-label="article signal chart">
            {bars.map((h, i) => <rect x={10 + i * 34} y={86 - h} width="20" height={h} rx="4" />)}
          </svg>
          <p class="muted tiny">Visual pacing indicator for long-form flow.</p>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-wrap { max-width: 1120px; padding-top: 2.6rem; }
  .back { font-size: .9rem; }

  .article-head { margin-top: .8rem; max-width: 780px; }
  .cat { margin: 0; font-size: .74rem; letter-spacing: .08em; text-transform: uppercase; color: #666; }
  h1 { margin: .35rem 0 .5rem; font-size: clamp(2rem, 7vw, 4.8rem); line-height: .94; letter-spacing: -.03em; font-weight: 560; }
  .sub { margin: 0; max-width: 62ch; font-size: 1.04rem; }
  .meta { margin-top: .75rem; font-size: .88rem; display: flex; gap: .4rem; flex-wrap: wrap; }

  .hero-media { margin: 1rem 0 1.2rem; }
  .hero-media img {
    width: 100%;
    max-height: 460px;
    object-fit: cover;
    border-radius: 18px;
    border: 1px solid #d4d4d4;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 760px) minmax(0, 300px);
    gap: 1.2rem;
    align-items: start;
  }

  .prose {
    background: #f7f7f7;
    border: 1px solid #dadada;
    border-radius: 18px;
    padding: 1.3rem 1.25rem;
  }
  .prose :global(p) { color: #1f1f1f; font-size: 1.07rem; line-height: 1.85; margin: 0 0 1rem; }
  .prose :global(h2),
  .prose :global(h3) { margin: 1.25rem 0 .6rem; line-height: 1.14; letter-spacing: -.01em; }
  .prose :global(h2) { font-size: clamp(1.35rem, 3.2vw, 2rem); }
  .prose :global(h3) { font-size: clamp(1.08rem, 2.7vw, 1.45rem); }
  .prose :global(ul),
  .prose :global(ol) { margin: 0 0 1.1rem 1.2rem; }
  .prose :global(li) { margin: .35rem 0; line-height: 1.75; }
  .prose :global(blockquote) {
    margin: 1rem 0;
    border-left: 3px solid #222;
    padding: .2rem 0 .2rem .85rem;
    color: #303030;
  }
  .prose :global(img) {
    width: 100%;
    border-radius: 14px;
    border: 1px solid #ddd;
    margin: .9rem 0 1.1rem;
  }

  .side {
    position: sticky;
    top: 1rem;
    padding: 1rem;
    border-radius: 16px;
  }
  .side-k { margin: 0 0 .5rem; font-size: .73rem; text-transform: uppercase; letter-spacing: .08em; color: #666; }
  .side ul { margin: 0; padding-left: 1rem; }
  .side li { margin: .3rem 0; font-size: .9rem; color: #333; }
  .chart-wrap { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #d6d6d6; }
  .chart-wrap svg { width: 100%; height: auto; }
  .chart-wrap rect { fill: #8d8d8d; }
  .tiny { font-size: .78rem; margin: .3rem 0 0; }

  @media (max-width: 980px) {
    .content-grid { grid-template-columns: 1fr; }
    .side { position: static; }
  }
</style>