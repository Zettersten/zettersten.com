---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id.replace(/\.mdx?$/, '') }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const estimateReadingMinutes = Math.max(4, Math.round(post.body.split(/\s+/).length / 220));
---

<BaseLayout title={`${post.data.title} — Erik Zettersten`} description={post.data.description} image={post.data.coverImage || '/og-default.svg'}>
  <Nav />
  <main class="container article-wrap">
    <a href="/blog" class="back muted">← Back to blog</a>

    <header class="article-head">
      <p class="cat">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="sub">{post.data.description}</p>
      <p class="meta muted">
        <span>Erik Zettersten</span>
        <span>•</span>
        <span>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
        <span>•</span>
        <span>{estimateReadingMinutes} min read</span>
      </p>
    </header>

    {post.data.coverImage && (
      <figure class="hero-media">
        <img src={post.data.coverImage} alt={post.data.title} loading="eager" />
      </figure>
    )}

    <section class="content-grid">
      <article class="prose">
        <Content />
      </article>

      {headings.length > 0 && (
        <aside class="toc glass">
          <p class="toc-k">On this page</p>
          <ul>
            {headings.slice(0, 8).map((h: { text: string; slug: string }) => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </aside>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-wrap { max-width: 1140px; padding-top: 2.15rem; }
  .back { font-size: .9rem; }

  .article-head { margin-top: .7rem; max-width: 820px; }
  .cat {
    margin: 0;
    font-size: .72rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #707070;
  }

  h1 {
    margin: .32rem 0 .5rem;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2rem, 5.7vw, 4rem);
    line-height: .98;
    letter-spacing: -.01em;
  }

  .sub {
    margin: 0;
    max-width: 68ch;
    color: #323232;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .meta {
    margin-top: .7rem;
    font-size: .86rem;
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
  }

  .hero-media { margin: 1.1rem 0 1.25rem; }
  .hero-media img {
    width: 100%;
    max-height: 460px;
    object-fit: cover;
    border-radius: 18px;
    border: 1px solid #d7d7d7;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 780px) minmax(0, 280px);
    gap: 1.15rem;
    align-items: start;
  }

  .prose {
    background: #f7f7f7;
    border: 1px solid #d8d8d8;
    border-radius: 18px;
    padding: 1.45rem 1.4rem;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: Georgia, 'Times New Roman', serif;
    line-height: 1.16;
    letter-spacing: -.01em;
    scroll-margin-top: 90px;
  }
  .prose :global(h2) { margin: 1.8rem 0 .7rem; font-size: clamp(1.45rem, 3vw, 2.08rem); }
  .prose :global(h3) { margin: 1.4rem 0 .55rem; font-size: clamp(1.16rem, 2.6vw, 1.5rem); }

  .prose :global(p) {
    color: #1f1f1f;
    font-size: 1.06rem;
    line-height: 1.88;
    margin: 0 0 1.05rem;
    max-width: 68ch;
  }

  .prose :global(ul),
  .prose :global(ol) { margin: 0 0 1.15rem 1.15rem; }
  .prose :global(li) { margin: .38rem 0; line-height: 1.72; }

  .prose :global(blockquote) {
    margin: 1.2rem 0;
    padding: .7rem .95rem;
    border-left: 3px solid #c7632c;
    background: #f4ebe6;
    border-radius: 10px;
  }

  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid #d6d6d6;
    margin: 1.45rem 0;
  }

  .prose :global(img) {
    width: 100%;
    border-radius: 14px;
    border: 1px solid #ddd;
    margin: 1rem 0 1.15rem;
  }

  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: .87em;
    background: #ececec;
    padding: .15rem .35rem;
    border-radius: 5px;
  }

  .prose :global(pre) {
    overflow: auto;
    background: #141414;
    color: #f5f5f5;
    border-radius: 12px;
    padding: .9rem;
    border: 1px solid #2f2f2f;
    margin: 1rem 0 1.2rem;
  }
  .prose :global(pre code) { background: transparent; padding: 0; color: inherit; }

  .toc {
    position: sticky;
    top: 1rem;
    padding: .95rem;
    border-radius: 16px;
  }
  .toc-k {
    margin: 0 0 .5rem;
    font-size: .72rem;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: #6f6f6f;
  }
  .toc ul { margin: 0; padding-left: 1rem; }
  .toc li { margin: .34rem 0; }
  .toc a {
    font-size: .9rem;
    color: #343434;
    text-decoration: none;
    line-height: 1.35;
  }
  .toc a:hover { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 980px) {
    .content-grid { grid-template-columns: 1fr; }
    .toc { position: static; }
    .prose { padding: 1.15rem 1rem; }
  }
</style>
