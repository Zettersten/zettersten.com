---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id.replace(/\.md$/, '') }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Erik Zettersten`} description={post.data.description}>
  <Nav />
  <main class="container article-wrap">
    <a href="/blog" class="muted back">← Back to hot takes</a>

    <header class="article-head">
      <p class="kicker">Article</p>
      <h1>{post.data.title}</h1>
      <p class="sub muted">{post.data.description}</p>
      <p class="muted date">{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
    </header>

    <article class="glass prose">
      <Content />
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-wrap { padding-top: 3rem; max-width: 860px; }
  .back { font-size: .9rem; }

  .article-head { margin-top: .75rem; }
  .kicker { margin: 0; text-transform: uppercase; letter-spacing: .08em; color: #6a6a6a; font-size: .74rem; font-weight: 700; }
  h1 { margin: .35rem 0 .55rem; font-size: clamp(2rem, 7vw, 4.4rem); line-height: .94; letter-spacing: -.03em; font-weight: 550; }
  .sub { margin: 0; max-width: 62ch; font-size: 1.06rem; }
  .date { margin-top: .75rem; font-size: .9rem; }

  .prose {
    margin-top: 1.1rem;
    padding: 1.4rem;
    border-radius: 28px;
    background: #f5f5f5;
  }
  .prose :global(p) { color: #1f1f1f; font-size: 1.08rem; line-height: 1.85; margin: 0 0 1rem; }
  .prose :global(h2),
  .prose :global(h3) { margin: 1.2rem 0 .6rem; line-height: 1.15; letter-spacing: -.01em; }
  .prose :global(h2) { font-size: clamp(1.35rem, 3.5vw, 2rem); }
  .prose :global(h3) { font-size: clamp(1.1rem, 3vw, 1.5rem); }
  .prose :global(ul),
  .prose :global(ol) { margin: 0 0 1.1rem 1.2rem; }
  .prose :global(li) { margin: .35rem 0; line-height: 1.75; }
  .prose :global(strong) { font-weight: 650; }
  .prose :global(code) {
    background: #ececec;
    border: 1px solid #dfdfdf;
    color: #1a1a1a;
    padding: .12rem .35rem;
    border-radius: .35rem;
    font-size: .92em;
  }

  @media (max-width: 760px) {
    .prose { padding: 1rem; border-radius: 20px; }
  }
</style>