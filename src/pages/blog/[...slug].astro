---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const estimateReadingMinutes = Math.max(4, Math.round(post.body.split(/\s+/).length / 220));
const site = Astro.site?.toString() ?? 'https://zettersten.com';
const slug = post.id.replace(/\.mdx?$/, '');
const canonicalUrl = new URL(`/blog/${slug}/`, site).toString();
const publishedISO = post.data.date.toISOString();
const publishedText = post.data.date.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
const year = post.data.date.getFullYear();

const apaCitation = `Zettersten, E. (${year}, ${post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}). ${post.data.title}. zettersten.com. ${canonicalUrl}`;
const mlaCitation = `Zettersten, Erik. "${post.data.title}." zettersten.com, ${publishedText}, ${canonicalUrl}.`;

const bibtexCitation = `@online{zettersten_${slug.replace(/-/g, '_')},\n  author = {Erik Zettersten},\n  title = {${post.data.title}},\n  year = {${year}},\n  month = {${post.data.date.toLocaleDateString('en-US', { month: 'short' }).toLowerCase()}},\n  url = {${canonicalUrl}},\n  note = {Accessed: ${new Date().toISOString().slice(0, 10)}}\n}`;
---

<BaseLayout
  title={`${post.data.title} — Erik Zettersten`}
  description={post.data.description}
  image={post.data.coverImage || '/og-default.svg'}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={publishedISO} />
    <meta property="article:author" content="Erik Zettersten" />
    <meta property="article:section" content={post.data.category} />
    {post.data.tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="citation_title" content={post.data.title} />
    <meta name="citation_author" content="Erik Zettersten" />
    <meta name="citation_publication_date" content={publishedISO.slice(0, 10)} />
    <meta name="citation_online_date" content={publishedISO.slice(0, 10)} />
    <meta name="citation_journal_title" content="zettersten.com" />
    <meta name="citation_language" content="en" />
    <meta name="citation_public_url" content={canonicalUrl} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: post.data.title,
        datePublished: publishedISO,
        dateModified: publishedISO,
        author: { '@type': 'Person', name: 'Erik Zettersten' },
        publisher: { '@type': 'Person', name: 'Erik Zettersten' },
        mainEntityOfPage: canonicalUrl,
        url: canonicalUrl,
      })}
    />
  </Fragment>
  <Nav />
  <main class="container article-wrap">
    <a href="/blog" class="back muted">← Back to blog</a>

    <header class="article-head">
      <p class="cat">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="sub">{post.data.description}</p>
      <p class="meta muted">
        <span>Erik Zettersten</span>
        <span>•</span>
        <span
          >{
            post.data.date.toLocaleDateString('en-US', {
              month: 'long',
              day: 'numeric',
              year: 'numeric',
            })
          }</span
        >
        <span>•</span>
        <span>{estimateReadingMinutes} min read</span>
      </p>
    </header>

    {
      post.data.coverImage && (
        <figure class="hero-media">
          <img src={post.data.coverImage} alt={post.data.title} loading="eager" />
        </figure>
      )
    }

    <section class="content-grid">
      <article class="prose">
        <Content />
      </article>

      {
        headings.length > 0 && (
          <aside class="toc glass">
            <p class="toc-k">On this page</p>
            <ul>
              {headings.slice(0, 8).map((h: { text: string; slug: string }) => (
                <li>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
    </section>

    <section class="cite glass" aria-labelledby="cite-title">
      <h2 id="cite-title">Cite this article</h2>
      <p class="muted">Use this canonical link when referencing this piece:</p>
      <p><a href={canonicalUrl}>{canonicalUrl}</a></p>

      <h3>APA</h3>
      <p>{apaCitation}</p>

      <h3>MLA</h3>
      <p>{mlaCitation}</p>

      <h3>BibTeX</h3>
      <pre><code>{bibtexCitation}</code></pre>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-wrap {
    max-width: 1140px;
    padding-top: 2.15rem;
  }
  .back {
    font-size: 0.9rem;
  }

  .article-head {
    margin-top: 0.7rem;
    max-width: 820px;
  }
  .cat {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #707070;
  }

  h1 {
    margin: 0.32rem 0 0.5rem;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5.7vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
  }

  .sub {
    margin: 0;
    max-width: 68ch;
    color: #323232;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .meta {
    margin-top: 0.7rem;
    font-size: 0.86rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .hero-media {
    margin: 1.1rem 0 1.25rem;
  }
  .hero-media img {
    width: 100%;
    max-height: 460px;
    object-fit: cover;
    border-radius: 18px;
    border: 1px solid #d7d7d7;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 780px) minmax(0, 280px);
    gap: 1.15rem;
    align-items: start;
  }

  .prose {
    background: #f7f7f7;
    border: 1px solid #d8d8d8;
    border-radius: 18px;
    padding: 1.45rem 1.4rem;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: var(--font-serif);
    line-height: 1.16;
    letter-spacing: -0.01em;
    scroll-margin-top: 90px;
  }
  .prose :global(h2) {
    margin: 1.8rem 0 0.7rem;
    font-size: clamp(1.45rem, 3vw, 2.08rem);
  }
  .prose :global(h3) {
    margin: 1.4rem 0 0.55rem;
    font-size: clamp(1.16rem, 2.6vw, 1.5rem);
  }

  .prose :global(p) {
    color: #1f1f1f;
    font-size: 1.06rem;
    line-height: 1.88;
    margin: 0 0 1.05rem;
    max-width: 68ch;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.15rem 1.15rem;
  }
  .prose :global(li) {
    margin: 0.38rem 0;
    line-height: 1.72;
  }

  .prose :global(blockquote) {
    margin: 1.2rem 0;
    padding: 0.7rem 0.95rem;
    border-left: 3px solid #c7632c;
    background: #f4ebe6;
    border-radius: 10px;
  }

  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid #d6d6d6;
    margin: 1.45rem 0;
  }

  .prose :global(img) {
    width: 100%;
    border-radius: 14px;
    border: 1px solid #ddd;
    margin: 1rem 0 1.15rem;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.87em;
    background: #ececec;
    padding: 0.15rem 0.35rem;
    border-radius: 5px;
  }

  .prose :global(pre) {
    overflow: auto;
    background: #141414;
    color: #f5f5f5;
    border-radius: 12px;
    padding: 0.9rem;
    border: 1px solid #2f2f2f;
    margin: 1rem 0 1.2rem;
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .toc {
    position: sticky;
    top: 1rem;
    padding: 0.95rem;
    border-radius: 16px;
  }
  .toc-k {
    margin: 0 0 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: #6f6f6f;
  }
  .toc ul {
    margin: 0;
    padding-left: 1rem;
  }
  .toc li {
    margin: 0.34rem 0;
  }
  .toc a {
    font-size: 0.9rem;
    color: #343434;
    text-decoration: none;
    line-height: 1.35;
  }
  .toc a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cite {
    margin-top: 1rem;
    padding: 1rem 1.1rem;
    max-width: 780px;
  }
  .cite h2 {
    margin: 0 0 0.4rem;
    font-size: 1.35rem;
  }
  .cite h3 {
    margin: 0.8rem 0 0.25rem;
    font-size: 1rem;
    letter-spacing: 0.02em;
  }
  .cite p {
    margin: 0 0 0.5rem;
    line-height: 1.65;
    overflow-wrap: anywhere;
  }
  .cite pre {
    overflow: auto;
    background: #141414;
    color: #f5f5f5;
    border-radius: 10px;
    padding: 0.75rem;
    border: 1px solid #2f2f2f;
    margin: 0;
  }

  @media (max-width: 980px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
    .toc {
      position: static;
    }
    .prose {
      padding: 1.15rem 1rem;
    }
  }
</style>
