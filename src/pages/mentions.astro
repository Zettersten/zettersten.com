---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { mentions } from '../data/mentions';
---

<BaseLayout
  title="Mentions & Media — Erik Zettersten"
  description="External talks, features, and internet mentions of Erik Zettersten."
  image="/og/mentions.svg"
>
  <Nav />
  <main id="main-content" class="container page page-shell">
    <header class="page-hero">
      <p class="kicker">Mentions & Media</p>
      <h1 class="page-title">
        Public receipts: where the work gets cited, featured, and discussed.
      </h1>
      <p class="page-subtitle">
        Interviews, features, and references that document outcomes in the open.
      </p>
    </header>

    <section class="list" aria-label="Mentions list">
      {
        mentions.map((m) => (
          <article class="glass card">
            <img src={m.thumbnail} alt={m.title} loading="lazy" />
            <div>
              <small>{m.outlet}</small>
              <h2>{m.title}</h2>
              <p>{m.story}</p>
              <p class="muted">{m.summary}</p>
              <a class="btn primary" href={m.url} target="_blank" rel="noreferrer">
                Read mention
              </a>
            </div>
          </article>
        ))
      }
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
  }
  .list {
    margin-top: 1rem;
    display: grid;
    gap: 0.9rem;
  }
  .card {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 0.9rem;
    padding: 0.8rem;
    border-radius: 18px;
  }
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 1px solid #d6d6d6;
    border-radius: 12px;
  }
  .card small {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand);
    font-weight: 700;
  }
  .card h2 {
    margin: 0.34rem 0 0.45rem;
    font-size: 1.45rem;
  }
  .card p {
    margin: 0.28rem 0;
    line-height: 1.62;
  }
  @media (max-width: 900px) {
    .card {
      grid-template-columns: 1fr;
    }
  }
</style>
