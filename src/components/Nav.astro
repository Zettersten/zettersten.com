---
import { Icon } from 'astro-icon/components';

const pathname = Astro.url.pathname;
const links = [
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Work' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Writing' },
];

const isActive = (href: string) => pathname === href || pathname.startsWith(`${href}/`);
---

<header class="container nav-wrap">
  <nav class="nav" aria-label="Primary">
    <a href="/" class="logo" aria-label="Go to homepage">
      <Icon name="tabler:sparkles" width="16" height="16" />
    </a>
    <div class="links">
      {
        links.map((link) => (
          <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
            {link.label}
          </a>
        ))
      }
    </div>
    <a class="call" href="/mentions" aria-current={isActive('/mentions') ? 'page' : undefined}
      >Press <Icon name="tabler:arrow-up-right" width="12" height="12" /></a
    >
  </nav>
</header>

<style>
  .nav-wrap {
    padding-top: 1.15rem;
  }
  .nav {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.2rem;
    padding: 0.7rem 0;
  }
  .logo {
    font-size: 1.15rem;
    display: inline-flex;
    align-items: center;
  }
  .links {
    display: flex;
    gap: 1.2rem;
    color: #444;
    font-size: 0.82rem;
  }

  .links a,
  .call {
    position: relative;
  }

  .links a::after,
  .call::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1.5px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.18s ease;
  }

  .links a:hover,
  .call:hover {
    color: #1f2f56;
  }

  .links a:hover::after,
  .call:hover::after,
  .links a[aria-current='page']::after,
  .call[aria-current='page']::after {
    transform: scaleX(1);
  }

  .links a[aria-current='page'],
  .call[aria-current='page'] {
    color: #1f1f1f;
  }
  .call {
    font-size: 0.82rem;
    color: #2f2f2f;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }
  @media (max-width: 840px) {
    .nav {
      grid-template-columns: 1fr;
      gap: 0.55rem;
      align-items: start;
    }

    .logo {
      order: 1;
    }

    .links {
      order: 2;
      gap: 0.7rem;
      font-size: 0.78rem;
      overflow-x: auto;
      white-space: nowrap;
      padding-bottom: 0.25rem;
      scrollbar-width: thin;
    }

    .call {
      order: 3;
      font-size: 0.78rem;
      width: fit-content;
    }
  }
</style>
