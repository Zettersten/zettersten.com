---
interface Props {
  title?: string;
  tone?: 'note' | 'warning' | 'insight';
}
const { title = 'Note', tone = 'note' } = Astro.props;
---

<aside class={`callout ${tone}`}>
  <p class="title">{title}</p>
  <div class="content"><slot /></div>
</aside>

<style>
  .callout {
    border: 1px solid #ddcfc7;
    border-left: 3px solid #c7632c;
    border-radius: 12px;
    padding: 0.9rem 0.95rem;
    margin: 1.1rem 0;
    background: #f4ebe6;
  }
  .title {
    margin: 0 0 0.25rem;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #7a5b4a;
    font-weight: 600;
  }

  .callout.warning {
    border-left-color: #b2461f;
    background: #f8e8e1;
  }

  .callout.insight {
    border-left-color: #4e6a90;
    border-color: #cfd9e7;
    background: #ebf1f8;
  }

  .content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
